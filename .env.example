# Copia este archivo a .env.local y completa tus claves.
# .env.local está en .gitignore: NUNCA subas claves reales al repositorio.

# API de Claude (Anthropic) — https://console.anthropic.com/  (Fase 6)
ANTHROPIC_API_KEY=

# Embeddings de Voyage AI — https://dashboard.voyageai.com/  (Fases 4-5)
VOYAGE_API_KEY=
# Opcional: modelo de embeddings (por defecto voyage-3.5, 1024 dims —
# debe coincidir con vector(1024) del esquema de db/migrations/)
# VOYAGE_MODEL=voyage-3.5

# Postgres + pgvector (Supabase) — cadena de conexión URI  (Fases 4-5)
# Supabase: Project Settings → Database → Connection string (URI).
# Tras configurarla, aplica el esquema con: npm run db:migrate
DATABASE_URL=
